# === Link Finder API ===
# Get your key at https://app.link-finder.net/account/ (Booster plan or higher required)
LINK_FINDER_API_KEY=your_link_finder_api_key_here

# === Transport ===
# stdio -> local clients (Claude Desktop, Cursor, etc.). Default.
# http  -> hosted Streamable HTTP server, endpoint /mcp. RECOMMENDED for hosting
#          (robust behind Render/Railway/Fly proxies). Requires MCP_BEARER_TOKEN.
# sse   -> legacy SSE server, endpoint /sse. Use only if your client needs it.
MCP_TRANSPORT=stdio

# === Hosted-mode auth (only used when MCP_TRANSPORT=http or sse) ===
# Shared secret clients must send as "Authorization: Bearer <token>".
MCP_BEARER_TOKEN=change_me_to_a_long_random_string

# === Streamable HTTP tuning (only used when MCP_TRANSPORT=http) ===
# Stateless = no per-session server state; most robust behind proxies. Default true.
MCP_STATELESS_HTTP=true
# Return plain JSON instead of SSE-framed responses. Leave false unless your client needs it.
MCP_JSON_RESPONSE=false

# === Networking (hosted mode) ===
# Render and most PaaS inject PORT automatically; this is only a fallback.
PORT=8000
HOST=0.0.0.0

# === DNS-rebinding protection (hosted mode, optional) ===
# Leave both empty to disable host checking (the bearer token already guards
# the endpoint) — this is what lets it work behind Render/Railway/Fly proxies.
# To opt back in, list the public host(s)/origin(s). Supports a ":*" port wildcard.
# MCP_ALLOWED_HOSTS=your-app.onrender.com,localhost:*
# MCP_ALLOWED_ORIGINS=https://your-app.onrender.com

# === Local result storage (best-practice logging) ===
# Where search results + searchHistory.json are written. Set empty to disable saving.
LINK_FINDER_DATA_DIR=data
